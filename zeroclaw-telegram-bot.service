[Unit]
Description=ZeroClaw Telegram Bot
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.zeroclaw/workspace
ExecStart=/usr/bin/python3 /root/.zeroclaw/workspace/telegram_bot_final.py
Restart=always
RestartSec=10
StandardOutput=append:/root/.zeroclaw/workspace/bot.log
StandardError=append:/root/.zeroclaw/workspace/bot.log
Environment=PYTHONUNBUFFERED=1

# Ограничения ресурсов
MemoryMax=512M
CPUQuota=50%

[Install]
WantedBy=multi-user.target